# Vendored code - exclude from stats
Frontend/** linguist-vendored

# Force detection of Java as primary language
*.java linguist-language=Java linguist-detectable
demo/**/*.java linguist-language=Java linguist-detectable

# Lower weight for HTML/CSS
*.html linguist-language=HTML
*.css linguist-language=CSS

# Mark config files
pom.xml linguist-language=XML
*.properties linguist-language=INI